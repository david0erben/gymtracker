rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isOwnData(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isValidMainDocument() {
      return request.resource.data.keys().hasOnly([
          "version",
          "workouts",
          "bodyweight",
          "draftWorkout",
          "updatedAt"
        ])
        && request.resource.data.version == 2
        && request.resource.data.workouts is list
        && request.resource.data.bodyweight is list
        && request.resource.data.draftWorkout is map
        && request.resource.data.updatedAt is timestamp;
    }

    match /users/{userId}/data/main {
      allow read, delete: if isOwnData(userId);
      allow create, update: if isOwnData(userId) && isValidMainDocument();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

